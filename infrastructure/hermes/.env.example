# Hermes Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit the real .env file with secrets to version control

# --- OpenRouter (Fallback Provider) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- GitHub (CMO shared) ---
# GITHUB_TOKEN / GITHUB_READ_PAT: shared READ token for cloning/fetching across all product repos.
# MOXIE_GITHUB_WRITE_PAT: WRITE token used only when pushing changes to the moxie repo.
GITHUB_READ_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=your_github_token_here
MOXIE_GITHUB_WRITE_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx

# --- Telegram (Moxie Bot) ---
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Umami Analytics (shared) ---
# Get your API key from your Umami dashboard
UMAMI_API_KEY=api_xxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenCode Go (Primary Provider) ---
# Get your key at: https://opencode.ai
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here
